# Same Supabase project as the Next app (copy values from root .env NEXT_PUBLIC_*).
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Origin of the Next.js API (no trailing slash). For a physical device use your machine LAN IP, e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_URL="http://localhost:3000"
