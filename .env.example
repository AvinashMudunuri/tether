# Database (Prisma) - use Supabase pooler URL for serverless (add ?pgbouncer=true for pooler)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Tether <noreply@yourdomain.com>"

# App URL (for emails, redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Inngest (job queue for reminders) - get keys from https://app.inngest.com
# INNGEST_SIGNING_KEY="signkey-xxx"
# INNGEST_EVENT_KEY="eventkey-xxx"

# Optional: E2E tests (create test account first)
# TEST_USER_EMAIL="test@example.com"
# TEST_USER_PASSWORD="your-test-password"

# Optional: Error tracking
# SENTRY_DSN="https://xxx@sentry.io/xxx"
