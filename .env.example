# Database (Prisma)
# DATABASE_URL: pooler (port 6543) for runtime - migrations need DIRECT_URL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: direct connection (port 5432) - required for Prisma migrations (pooler blocks advisory locks)
DIRECT_URL="postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Tetherly <noreply@yourdomain.com>"

# Twilio (WhatsApp reminders) - https://www.twilio.com/console
# TWILIO_ACCOUNT_SID="ACxxx"
# TWILIO_AUTH_TOKEN="xxx"
# TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"  # Sandbox for testing

# App URL (for emails, redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Inngest (job queue for reminders) - get keys from https://app.inngest.com
# INNGEST_SIGNING_KEY="signkey-xxx"
# INNGEST_EVENT_KEY="eventkey-xxx"
# INNGEST_DEV=0  # Set in Vercel Production to force Cloud mode (see docs/INNGEST_TROUBLESHOOTING.md)

# Optional: E2E tests (create test account first)
# TEST_USER_EMAIL="test@example.com"
# TEST_USER_PASSWORD="your-test-password"

# Optional: Error tracking
# SENTRY_DSN="https://xxx@sentry.io/xxx"
