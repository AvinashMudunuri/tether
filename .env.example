# Database (Prisma)
# DATABASE_URL: pooler (port 6543) for runtime - migrations need DIRECT_URL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: direct connection (port 5432) - required for Prisma migrations (pooler blocks advisory locks)
DIRECT_URL="postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Tetherly <noreply@yourdomain.com>"

# Twilio (SMS reminders) - https://www.twilio.com/console
# TWILIO_ACCOUNT_SID="ACxxx"
# TWILIO_AUTH_TOKEN="xxx"
# TWILIO_PHONE_NUMBER="+1234567890"  # Your Twilio phone number (SMS-capable)

# App URL (for emails, redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Expo mobile app (apps/mobile — copy apps/mobile/.env.example; use LAN IP for device + NEXT dev)
# EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# EXPO_PUBLIC_API_URL="http://localhost:3000"
# Supabase Dashboard → Authentication → URL configuration: add redirect e.g. tether://** for native OAuth/magic links (matches app.json scheme).

# Inngest (job queue for reminders) - get keys from https://app.inngest.com
# INNGEST_SIGNING_KEY="signkey-xxx"
# INNGEST_EVENT_KEY="eventkey-xxx"
# INNGEST_DEV=0  # Set in Vercel Production to force Cloud mode (see docs/INNGEST_TROUBLESHOOTING.md)

# Optional: E2E tests (create test account first)
# TEST_USER_EMAIL="test@example.com"
# TEST_USER_PASSWORD="your-test-password"

# OpenAI (quick capture - natural language task parsing)
# OPENAI_API_KEY="sk-xxx"

# Optional: Rate limiting (Upstash Redis) - https://console.upstash.com
# Without these, auth/API are not rate limited
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# Optional: Error tracking (Sentry) - https://sentry.io
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"  # Server + Edge
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"  # Client (use same DSN)
# Source maps (for readable stack traces in CI/production):
# SENTRY_ORG="your-org-slug"      # Sentry org slug (Settings → Organization)
# SENTRY_PROJECT="your-project"  # Project slug (Settings → Projects)
# SENTRY_AUTH_TOKEN="sntrys_xxx" # Create at Sentry → Settings → Auth Tokens

# Firebase (push notifications) - https://console.firebase.google.com
# NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
# NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:xxx"
# NEXT_PUBLIC_FIREBASE_VAPID_KEY="BKagOny0KF_2pCJQ3m...."  # Web Push key from Firebase Console
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'  # JSON string (single-line)
# Or use file path (recommended - multi-line JSON in .env fails):
# FIREBASE_SERVICE_ACCOUNT_PATH="path/to/service-account.json"