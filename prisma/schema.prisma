// Prisma schema for Tetherly - see docs/PRD.md
// User identity is managed by Supabase Auth; userId references auth.users.id

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Appointment {
  id             String   @id @default(cuid())
  userId         String
  title          String
  date           DateTime @db.Date
  time           String
  timezoneOffset Int?     // minutes, from Date.getTimezoneOffset() - used to interpret date+time as user's local
  location       String?
  attendees  String?
  notes      String?  @db.Text
  recurrenceType    String?
  recurrenceEndDate DateTime? @db.Date
  status       String   @default("scheduled") // scheduled | completed | missed | cancelled
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  checklistItems ChecklistItem[]
  reminders       Reminder[]
  attachments    Attachment[]
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  title     String
  dueDate   DateTime? @db.Date
  status    String   @default("pending") // pending | completed | cancelled (overdue = pending + dueDate < today)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments TaskAttachment[]
}

model ChecklistItem {
  id            String   @id @default(cuid())
  appointmentId String
  label         String
  checked       Boolean  @default(false)
  order         Int      @default(0)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Reminder {
  id            String    @id @default(cuid())
  appointmentId String
  type          String    // 2_day, 1_day, 1_hour, 30_min, 15_min
  reminderTime  DateTime  // exact UTC time to send
  sent          Boolean   @default(false)
  sentAt        DateTime?
  emailSent     Boolean   @default(false)
  smsSent       Boolean   @default(false)
  pushSent      Boolean   @default(false)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Attachment {
  id            String   @id @default(cuid())
  appointmentId String
  fileName      String
  storagePath  String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  fileName  String
  storagePath String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
